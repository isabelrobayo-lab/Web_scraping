# =============================================================================
# Environment Variables — Scraping Platform Backend
# =============================================================================
# Copy this file to .env for local development.
# In production, provide values via secrets manager (AWS Parameter Store, etc.).
# NEVER commit .env with real credentials to version control.
# =============================================================================

# Application
APP_NAME="Plataforma Paramétrica de Web Scraping Inmobiliario"
APP_VERSION="0.1.0"
DEBUG=false

# Database (PostgreSQL + asyncpg)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/scraping_platform"
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Redis & Celery
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# API
API_V1_PREFIX="/api/v1"
